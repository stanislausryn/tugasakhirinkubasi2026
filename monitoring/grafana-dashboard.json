{
  "title": "MODERNO Dashboard",
  "uid": "moderno-main",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..|5..\"}[1m])) by (route)",
          "legendFormat": "Error - {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency Heatmap (p50 / p95 / p99)",
      "type": "heatmap",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top 5 Slowest Endpoints (p95 latency)",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route)))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Orders Created",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "order_created_total",
          "legendFormat": "Total Orders"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cart Items Added",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "cart_items_added_total",
          "legendFormat": "Total Items Added"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active HTTP Connections",
      "type": "gauge",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "Active Connections"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}